{
  "name": "difflens-cli",
  "version": "1.0.0",
  "description": "MCP server that gives AI coding agents visual diff capabilities for UI work",
  "type": "module",
  "bin": {
    "difflens": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "npx playwright install chromium",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "claude",
    "visual-diff",
    "screenshot",
    "ui-testing",
    "visual-regression",
    "playwright"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/byzkhan/difflens.git"
  },
  "homepage": "https://github.com/byzkhan/difflens",
  "bugs": {
    "url": "https://github.com/byzkhan/difflens/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chokidar": "^5.0.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.9.3"
  }
}
